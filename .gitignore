# Prerequisites
*.d

# Object files
*.o
*.ko
*.obj
*.elf

# Linker output
*.ilk
*.map
*.exp

# Precompiled Headers
*.gch
*.pch

# Libraries
*.lib
*.a
*.la
*.lo

# Shared objects (inc. Windows DLLs)
*.dll
*.so
*.so.*
*.dylib

# Executables
*.exe
*.out
*.app
*.i*86
*.x86_64
*.hex

# Debug files
*.dSYM/
*.su
*.idb
*.pdb

# Kernel Module Compile Results
*.mod*
*.cmd
.tmp_versions/
modules.order
Module.symvers
Mkfile.old
dkms.conf

# debug information files
*.dwo

# PHP Extension build artifacts.
# All of these are produced by `phpize` + `./configure`. None of them
# are project source — regenerate locally via `phpize && ./configure`.
/autom4te.cache/
/build/
/config.h
/config.h.in
/config.log
/config.status
/config.nice
/configure
/configure.ac
/libtool
/Makefile
/Makefile.fragments
/Makefile.objects
/run-tests.php
/.libs/
/modules/
*.dep

# Build artifacts in src/
src/.libs/
src/**/.libs/

# Coverage output (scripts/coverage.sh)
/coverage/

# gcov instrumentation artefacts
*.gcda
*.gcno

# llhttp bundled library (binaries only, keep sources and headers)
/deps/llhttp/lib/*.so
/deps/llhttp/lib/*.a

# IDE
.idea/

# Local test run logs
php_test_results_*.txt
.claude/
tests/bench/h2spec-results.txt
tests/bench/.h2spec-server.log

# Per-test scratch dirs created by phpt FILE blocks (cert/key throwaways
# generated by tls_gen_cert / h2_gen_cert / h3_gen_cert). Each test
# creates its own tmp-NNN/ alongside the .phpt and is responsible for
# cleaning up; ignore the directory itself so a failed run doesn't
# leave noise in `git status`.
tests/phpt/**/tmp-*/
compile_commands.json
fuzz/fuzz_multipart
fuzz/corpus/multipart/NEW_CORPUS

# libFuzzer artifacts — keep repo clean from mined corpus (regenerated
# at first run) and ignore crash/leak/timeout dumps.
fuzz/fuzz_multipart
fuzz/fuzz_http1_parser
fuzz/fuzz_h2_session
fuzz/fuzz_tls_handshake
fuzz/corpus/http1/*
!fuzz/corpus/http1/seed*
fuzz/corpus/h2/*
!fuzz/corpus/h2/seed*
fuzz/corpus/multipart/*
!fuzz/corpus/multipart/seed*
fuzz/crash-*
fuzz/leak-*
fuzz/timeout-*
fuzz/oom-*
