# EditorConfig for php-http-server
# https://editorconfig.org

root = true

# Default settings for all files
[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

# C source and header files
[*.{c,h}]
indent_style = tab
indent_size = 4
tab_width = 4
max_line_length = 100

# PHP files (tests, examples)
[*.php]
indent_style = tab
indent_size = 4
tab_width = 4

# Makefiles require tabs
[{Makefile,*.mk}]
indent_style = tab

# Configuration files
[*.{json,yml,yaml}]
indent_style = space
indent_size = 2

# Markdown
[*.md]
trim_trailing_whitespace = false
max_line_length = off

# Shell scripts
[*.sh]
indent_style = tab
indent_size = 4
